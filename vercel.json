{
  "version": 2,
  "builds": [
    { "src": "backend/api/index.js", "use": "@vercel/node" },
    { "src": "frontend/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "backend/api/index.js" },
    { "src": "/signup/(.*)", "dest": "frontend/signup/$1" },
    { "src": "/dashboard/(.*)", "dest": "frontend/dashboard/$1" },
    { "src": "/(.*)", "dest": "frontend/$1" }
  ]
}
